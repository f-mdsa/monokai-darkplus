  "description": "A combination of the classic Monokai theme with the default Visual Studio Code Dark+ theme.",
  "version": "1.0.2",
  "author": "Filipe Andrade (https://github.com/f-mdsa)",
  "icon": "images/monokai_vscode.png",
  "keywords": [
