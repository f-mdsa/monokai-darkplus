    "darkplus",
    "dark+",
    "monokai_vscode",
    "monokaidark",
    "highcontrast"
  ],
  "publisher": "f-mdsa",
  "repository": {
    "type": "git",
    "url": "https://github.com/f-mdsa/monokai-darkplus"
  },
  "engines": {
